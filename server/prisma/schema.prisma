// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique
  email        String      @unique
  passwordHash String      @map("password_hash")
  createdAt    DateTime    @default(now()) @map("created_at")
  deletedAt    DateTime?   @map("deleted_at")
  habits       UserHabit[]

  @@map("users")
}

enum RepeatTime {
  DAILY
  WEEKLY
  CUSTOM
}

model Habit {
  id          String    @id @default(uuid())
  name        String
  description String?
  categoryId  String?   @map("category_id")
  isDefault   Boolean   @default(false)
  deletedAt   DateTime? @map("deleted_at")

  category   Category?   @relation(fields: [categoryId], references: [id])
  userHabits UserHabit[]

  @@unique([name, isDefault])
  @@map("default_habits")
}

model UserHabit {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  habitId    String     @map("habit_id")
  repeatType RepeatTime @default(DAILY)
  interval   Int?       @map("repeat_interval")
  startDate  DateTime?  @map("start_date")
  endDate    DateTime?  @map("end_date")

  user  User       @relation(fields: [userId], references: [id])
  habit Habit      @relation(fields: [habitId], references: [id])
  logs  HabitLog[]
  days  HabitDay[]

  @@map("user_habits")
}

model Category {
  id    String  @id @default(uuid())
  name  String  @unique
  habit Habit[]

  @@map("categories")
}

enum Status {
  COMPLETED
  NOT_COMPLETED
  POSTPONED
}

model HabitLog {
  id          String   @id @default(uuid())
  date        DateTime
  userHabitId String   @map("user_habit_id")
  status      Status   @default(NOT_COMPLETED)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userHabit UserHabit @relation(fields: [userHabitId], references: [id], onDelete: Cascade)

  @@map("habit_logs")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model HabitDay {
  id          String    @id @default(uuid())
  userHabitId String    @map("user_habit_id")
  dayOfWeek   DayOfWeek @map("day_of_week")

  userHabit UserHabit @relation(fields: [userHabitId], references: [id], onDelete: Cascade)

  @@map("habit_days")
}
