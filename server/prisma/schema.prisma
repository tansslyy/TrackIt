// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  username     String? @unique
  email        String  @unique
  passwordHash String? @map("password_hash")

  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  avatarUrl String? @map("avatar_url")
  provider  String  @default("local")

  createdAt    DateTime      @default(now()) @map("created_at")
  deletedAt    DateTime?     @map("deleted_at")
  refreshToken RefreshToken?
  habits       UserHabit[]

  @@map("users")
}

enum RepeatTime {
  DAILY
  WEEKLY
  CUSTOM
}

model Habit {
  id          String    @id @default(uuid())
  name        String
  description String?
  categoryId  String?   @map("category_id")
  isDefault   Boolean   @default(false)
  deletedAt   DateTime? @map("deleted_at")

  category   Category?   @relation(fields: [categoryId], references: [id])
  userHabits UserHabit[]

  @@unique([name, isDefault])
  @@map("default_habits")
}

model UserHabit {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  habitId    String     @map("habit_id")
  repeatType RepeatTime @default(DAILY)
  interval   Int?       @map("repeat_interval")
  startDate  DateTime?  @map("start_date")
  endDate    DateTime?  @map("end_date")
  deletedAt  DateTime?  @map("deleted_at")

  user  User       @relation(fields: [userId], references: [id])
  habit Habit      @relation(fields: [habitId], references: [id])
  logs  HabitLog[]
  days  HabitDay[]

  @@map("user_habits")
}

model Category {
  id    String  @id @default(uuid())
  name  String  @unique
  habit Habit[]

  @@map("categories")
}

enum Status {
  COMPLETED
  NOT_COMPLETED
  POSTPONED
}

model HabitLog {
  id          String   @id @default(uuid())
  date        DateTime
  userHabitId String   @map("user_habit_id")
  status      Status   @default(NOT_COMPLETED)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userHabit UserHabit @relation(fields: [userHabitId], references: [id], onDelete: Cascade)

  @@map("habit_logs")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model HabitDay {
  id          String    @id @default(uuid())
  userHabitId String    @map("user_habit_id")
  dayOfWeek   DayOfWeek @map("day_of_week")

  userHabit UserHabit @relation(fields: [userHabitId], references: [id], onDelete: Cascade)

  @@map("habit_days")
}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hashedToken String   @map("hashed_token")
  revoked     Boolean  @default(false)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("refresh_tokens")
}

enum TokenType {
  VERIFICATION
  RESETTING
}

model EmailToken {
  token     String    @id @default(uuid())
  email     String
  type      TokenType @map("token_assignment")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("email_tokens")
}
